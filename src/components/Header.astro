---
import { SITE_TITLE } from '../consts';
import ThemeIcon from './ThemeIcon.astro'
import HeaderLink from './HeaderLink.astro';
---

<header class="m-0 px-4 bg-white dark:bg-zinc-900 shadow-[0_2px_8px_rgba(0,0,0,0.05)] dark:shadow-[0_2px_8px_rgba(0,0,0,0.3)]">
	<nav class="flex items-center justify-between">
		<h2 class="m-0 text-base">
			<a href="/" class="no-underline text-black dark:text-zinc-100">{SITE_TITLE}</a>
		</h2>
		<div>
			<ThemeIcon />
		</div>
		<div class="internal-links flex">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
            <HeaderLink href="/tags">Tags</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/now">Now</HeaderLink>
			<HeaderLink href="/screenshots">Images</HeaderLink>
		</div>
		<div class="social-links flex gap-2 max-[720px]:hidden">
			<a href="https://m.webtoo.ls/@astro" target="_blank" class="flex text-black dark:text-zinc-100 hover:text-gray-600 dark:hover:text-zinc-400 transition-colors">
				<span class="sr-only">Follow Astro on Mastodon</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
      d="M1.5 3A1.5 1.5 0 0 0 0 4.5v7A1.5 1.5 0 0 0 1.5 13h13A1.5 1.5 0 0 0 16 11.5v-7A1.5 1.5 0 0 0 14.5 3h-13Zm0 1h13a.5.5 0 0 1 .5.5v.379L8 8.083 1 4.879V4.5a.5.5 0 0 1 .5-.5Zm-.5 2.01 6.646 3.05a.75.75 0 0 0 .708 0L15 6.01V11.5a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5V6.01Z"

					<!-- d="M64 112c-8.8 0-16 7.2-16 16v22.1L220.5 291.7c20.7 17 50.4 17 71.1 0L464 150.1V128c0-8.8-7.2-16-16-16H64zM48 212.2V384c0 8.8 7.2 16 16 16H448c8.8 0 16-7.2 16-16V212.2L322 328.8c-38.4 31.5-93.7 31.5-132 0L48 212.2zM0 128C0 92.7 28.7 64 64 64H448c35.3 0 64 28.7 64 64V384c0 35.3-28.7 64-64 64H64c-35.3 0-64-28.7-64-64V128z" -->
					></path></svg
				>

			</a>
			<a href="https://twitter.com/michaelgame_dev" target="_blank" class="flex text-black dark:text-zinc-100 hover:text-gray-600 dark:hover:text-zinc-400 transition-colors">
				<span class="sr-only">Follow Michael on Twitter</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href="https://github.com/MichaelGame-Dev" target="_blank" class="flex text-black dark:text-zinc-100 hover:text-gray-600 dark:hover:text-zinc-400 transition-colors">
				<span class="sr-only">Go to Michael's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>

<div class="mt-2 px-4 bg-yellow-100 dark:bg-yellow-900 shadow-[0_2px_8px_rgba(0,0,0,0.05)] dark:shadow-[0_2px_8px_rgba(0,0,0,0.3)] outline outline-2 outline-yellow-600 dark:outline-yellow-500"> 
    <p class="text-center text-gray-900 dark:text-gray-100">Site under construction</p>
</div>
