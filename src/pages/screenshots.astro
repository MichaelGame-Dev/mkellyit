---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import meta from '../assets/screenshots/meta.json';

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/screenshots/*.{jpg,jpeg,png,webp,gif}'
);

// Sort meta by date descending (newest first)
const sorted = [...meta].sort(
  (a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()
);

// Match sorted meta entries to their glob'd image
const screenshots = await Promise.all(
  sorted.map(async (entry) => {
    const key = Object.keys(images).find((k) => k.endsWith(entry.filename));
    if (!key) return null;
    const { default: imageData } = await images[key]();
    return { ...entry, imageData };
  })
).then((results) => results.filter(Boolean));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Screenshots | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
  </head>
  <body>
    <Header />
    <main>
      <h1>Screenshots</h1>
      <section class="screenshot-grid">
        {screenshots.map((shot, index) => (
          <a
            href={shot.imageData.src}
            class="glightbox"
            data-gallery="screenshots"
            style={`--width: ${shot.imageData.width}; --height: ${shot.imageData.height};`}
          >
            <Image
              src={shot.imageData}
              alt={shot.alt}
              height={300}
              format="webp"
              loading={index < 12 ? 'eager' : 'lazy'}
            />
          </a>
        ))}
      </section>
    </main>
    <Footer />

    <script>
      import GLightbox from 'glightbox';
      GLightbox({ selector: '.glightbox' });
    </script>

    <style>
      h1 {
        padding: 1rem;
      }

      .screenshot-grid {
        --gap: 8px;
        --min-height: clamp(150px, 18vw, 300px);

        display: flex;
        flex-wrap: wrap;
        gap: var(--gap);
        padding: var(--gap);
      }

      /* Justified layout — images fill rows proportionally */
      .screenshot-grid a {
        flex-grow: calc(var(--width) * (100000 / var(--height)));
        flex-basis: calc(var(--min-height) * (var(--width) / var(--height)));
        aspect-ratio: var(--width) / var(--height);
        overflow: hidden;
        cursor: zoom-in;
      }

      .screenshot-grid a img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.2s ease;
      }

      .screenshot-grid a:hover img {
        transform: scale(1.03);
      }

      /* Prevents last row from stretching weirdly */
      .screenshot-grid::after {
        content: '';
        flex-grow: 1000000000;
      }
    </style>
  </body>
</html>
