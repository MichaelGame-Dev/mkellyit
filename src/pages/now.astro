---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Content, frontmatter } from '../content/now.mdx';

---

<!doctype html>
<html lang="en">
	<head> 
		<BaseHead title={frontmatter.title ?? SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main >
        <h1>{frontmatter.title}</h1>
        <p>Last updated: <FormattedDate date={new Date(frontmatter.updatedAt)} /></p>
        <Content />
        </main>
		<Footer />
        <style>
        </style>

	</body>
</html>
